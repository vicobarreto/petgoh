<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Se o arquivo/pasta existir, sirva normalmente
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d

  # Caso contrário, redirecione tudo para index.html (SPA fallback)
  RewriteRule ^ index.html [QSA,L]
</IfModule>

# =============================================
# PERFORMANCE: Compressão Gzip
# =============================================
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html
  AddOutputFilterByType DEFLATE text/css
  AddOutputFilterByType DEFLATE text/javascript
  AddOutputFilterByType DEFLATE application/javascript
  AddOutputFilterByType DEFLATE application/json
  AddOutputFilterByType DEFLATE application/xml
  AddOutputFilterByType DEFLATE image/svg+xml
  AddOutputFilterByType DEFLATE font/woff2
</IfModule>

# =============================================
# PERFORMANCE: Cache do Navegador
# =============================================
<IfModule mod_expires.c>
  ExpiresActive On

  # HTML — sem cache (sempre busca a versão mais nova)
  ExpiresByType text/html "access plus 0 seconds"

  # CSS e JS — cache de 1 ano (Vite coloca hash no nome do arquivo)
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"

  # Imagens — cache de 1 mês
  ExpiresByType image/png "access plus 1 month"
  ExpiresByType image/jpeg "access plus 1 month"
  ExpiresByType image/gif "access plus 1 month"
  ExpiresByType image/svg+xml "access plus 1 month"
  ExpiresByType image/webp "access plus 1 month"

  # Fontes — cache de 1 ano
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType font/woff "access plus 1 year"
  ExpiresByType application/font-woff2 "access plus 1 year"
</IfModule>

# Cache-Control headers para arquivos com hash no nome
<IfModule mod_headers.c>
  # Arquivos JS/CSS do Vite (possuem hash, seguro cachear)
  <FilesMatch "\.(js|css)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # HTML sempre fresco
  <FilesMatch "\.html$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
  </FilesMatch>
</IfModule>
